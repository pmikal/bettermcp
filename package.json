{
  "name": "bettermcp",
  "version": "0.0.1",
  "description": "Self-healing API gateway for AI agents — turn any OpenAPI spec into an MCP server with built-in observability, safety, and versioning",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "bettermcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "openapi",
    "ai-agents",
    "api-gateway",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@scalar/openapi-parser": "^0.25.2",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.6.2",
    "json-schema-faker": "^0.6.0",
    "zod": "^4.3.6"
  }
}
